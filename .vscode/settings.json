{
    "python.defaultInterpreterPath": "",
    "python.languageServer": "Pylance",
    "editor.semanticTokenColorCustomizations": {
        "[Dark+]": {
            "enabled": true,
            "rules": {
                "variable:python": "#9CDCFE",
                "magicFunction:python": "#d1d11b",
                "parameter:python": "#106fdb",
                "clsParameter:python": "#106fdb",
                "selfParameter:python": "#106fdb",
                "property:python": "#0b75ee",
                "intrinsic:python": "#c31a14",
                "variable.readonly": "#9a14c3"
            }
        }
    }
}